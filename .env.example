# Exemplo de Variáveis de Ambiente
# Copie este arquivo para .env.local em cada projeto

# ========================
# HOST
# ========================
# VITE_API_URL=http://localhost:3000/api
# VITE_AUTH_SECRET=seu_secret_jwt_aqui

# ========================
# MFE-INSCRIPTIONS
# ========================
# VITE_API_INSCRIPTIONS_URL=http://localhost:3000/api/inscriptions
# VITE_STRIPE_KEY=pk_test_sua_chave_aqui

# ========================
# MFE-SCIENTIFIC
# ========================
# VITE_API_SCIENTIFIC_URL=http://localhost:3000/api/scientific
# VITE_MAX_FILE_SIZE=10485760  # 10MB em bytes

# ========================
# MFE-SCHEDULE
# ========================
# VITE_API_SCHEDULE_URL=http://localhost:3000/api/schedule
# VITE_CALENDAR_API_KEY=sua_api_key_aqui

# ========================
# Notas
# ========================
# - Em desenvolvimento, use localhost
# - Em produção, use URLs do seu servidor
# - Nunca commita .env com valores reais
# - Use .env.example apenas como template
